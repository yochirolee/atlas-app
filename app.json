{
  "expo": {
    "name": "Atlas",
    "slug": "atlas-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "atlas-app",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ctenvios.atlas-app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Atlas needs camera access to scan QR codes and barcodes on packages.",
        "NSLocationWhenInUseUsageDescription": "Atlas uses your location to record coordinates for package scans and proof of delivery.",
        "UIBackgroundModes": [
          "fetch",
          "location"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "background-delivery-sync"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.ctenvios.app",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Atlas needs camera access to scan package QR codes and barcodes."
        }
      ],
      "expo-font",
      "expo-sqlite",
      "expo-location",
      "expo-background-fetch",
      "expo-task-manager",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "19f4fd99-c3bd-41b7-8605-bdb470ab656b"
      }
    }
  }
}
